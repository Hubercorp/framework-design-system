{{!< default}}
{{#post}}
<article class="ldh-article {{post_class}}">
  <header class="ldh-article__head">
    {{#if primary_tag}}<span class="ldh-kicker">{{primary_tag.name}}</span>{{/if}}
    <h1>{{title}}</h1>
    {{#if custom_excerpt}}<p>{{custom_excerpt}}</p>{{/if}}
    <div class="ldh-article__meta">{{authors}} · {{date format="D MMM YYYY"}} · {{reading_time}}</div>
  </header>
  {{#if feature_image}}
    <figure class="ldh-feature"><img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"></figure>
  {{/if}}
  <div class="gh-content">{{content}}</div>
</article>
{{/post}}
