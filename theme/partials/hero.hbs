<section class="ldh-hero">
  <div class="ldh-hero__copy">
    <span class="ldh-kicker">The Liège Data Hub by Jérôme Huberty</span>
    <h1>{{@custom.hero_title}}</h1>
    <h2>{{@custom.hero_subtitle}}</h2>
    <p>{{@custom.hero_description}}</p>
    <div class="ldh-actions">
      <a class="ldh-text-link" href="{{@custom.secondary_cta_url}}">{{@custom.secondary_cta_text}} <span aria-hidden="true">↗</span></a>
    </div>
    <div class="ldh-proof" aria-label="Areas of expertise">
      <span>Strategy</span><span>Architecture</span><span>Governance</span><span>AI delivery</span>
    </div>
  </div>
  <div class="ldh-hero__visual" aria-hidden="true">
    <div class="ldh-hero__disc"></div>
    <img
      class="ldh-hero__data-guy"
      src="https://drive.google.com/uc?export=view&id=1gKSTdMQplTzGMG56zANpU3OZvhALUJta"
      width="1500"
      height="1500"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      alt=""
    >
    <div class="ldh-lenses" aria-hidden="true">
      <span class="ldh-lens ldh-lens--1">Design</span>
      <span class="ldh-lens ldh-lens--2">Build</span>
      <span class="ldh-lens ldh-lens--3">Trust</span>
      <span class="ldh-lens ldh-lens--4">Align</span>
      <span class="ldh-lens ldh-lens--5">Validate</span>
      <span class="ldh-lens ldh-lens--6">Create</span>
      <span class="ldh-lens ldh-lens--7">Architect</span>
    </div>
  </div>
</section>
