{{!< default}}
{{#author}}
<section class="ldh-page-head">
  <span class="ldh-kicker">Author</span>
  <h1>{{name}}</h1>
  {{#if bio}}<p>{{bio}}</p>{{/if}}
</section>
{{/author}}
<section class="ldh-section"><div class="ldh-grid">{{#foreach posts}}{{> "post-card"}}{{/foreach}}</div>{{pagination}}</section>
